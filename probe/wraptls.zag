@import("../src/zrt/tls.zag")
fn main() i32 {
    let dns: DnsResult = dns_resolve("api.openai.com");
    let fd: i64 = net_connect_ip(dns.ip0, dns.ip1, dns.ip2, dns.ip3, 443);
    if (fd < 0) { _zag_println("connect fail"); return 1; }
    net_set_rcvtimeo(fd, 10);
    let priv: []u8 = tls_rand(32);
    let ch: []u8 = tls_client_hello("api.openai.com", tls_rand(32), tls_rand(32), x25519_base(priv));
    // test net_write for the record
    let hdr: *i8 = _zag_malloc(5);
    hdr[0] = 22 as i8; hdr[1] = 3 as i8; hdr[2] = 1 as i8;
    hdr[3] = ((ch.len >> 8) & 255) as i8; hdr[4] = (ch.len & 255) as i8;
    let w1: i64 = net_write(fd, hdr[0..5]);
    let w2: i64 = net_write(fd, ch);
    _zag_println(_zag_str_concat("net_write hdr=", _zag_i64_to_str(w1)));
    _zag_println(_zag_str_concat("net_write ch=", _zag_i64_to_str(w2)));
    // test net_read_blocking
    let buf: *i8 = _zag_malloc(64);
    let n: i64 = net_read_blocking(fd, buf, 64);
    _zag_println(_zag_str_concat("net_read_blocking n=", _zag_i64_to_str(n)));
    if (n > 0) { _zag_println(_zag_str_concat("hex: ", str_to_hex(buf[0..(n as i32)]))); }
    return 0;
}

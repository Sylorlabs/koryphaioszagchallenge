@import("../src/zrt/tls.zag")
fn main() i32 {
    let dns: DnsResult = dns_resolve("api.openai.com");
    let fd: i64 = net_connect_ip(dns.ip0, dns.ip1, dns.ip2, dns.ip3, 443);
    net_set_rcvtimeo(fd, 8);
    let conn: *TlsConn = tls_new_conn(fd);
    _zag_println(_zag_str_concat("conn.fd=", _zag_i64_to_str(conn.*.fd)));
    let ch: []u8 = tls_client_hello("api.openai.com", tls_rand(32), tls_rand(32), x25519_base(tls_rand(32)));
    // send via RAW writes but read via tls_read_record(conn.fd)
    let hdr: *i8 = _zag_malloc(5);
    hdr[0] = 22 as i8; hdr[1] = 3 as i8; hdr[2] = 1 as i8;
    hdr[3] = ((ch.len >> 8) & 255) as i8; hdr[4] = (ch.len & 255) as i8;
    net_write(conn.*.fd, hdr[0..5]);
    net_write(conn.*.fd, ch);
    let rec: TlsRecord = tls_read_record(conn.*.fd);
    _zag_println(_zag_str_concat("RAW-send + tls_read_record ok=", _zag_i64_to_str(rec.ok as i64)));
    _zag_println(_zag_str_concat("  ctype=", _zag_i64_to_str(rec.ctype as i64)));
    _zag_println(_zag_str_concat("  len=", _zag_i64_to_str(rec.payload.len as i64)));
    return 0;
}

// probe/x25test.zag — RFC 7748 §5.2/§6.1 test vectors for src/zrt/tls_x25519.zag.
//
// Build/run:
//   znc probe/x25test.zag -o build/x25test --run
// Prints one PASS/FAIL line per check and exits non-zero on any failure.

@import("../src/zrt/tls_x25519.zag")

struct TestCtx {
    failures: i32,
    total: i32,
}

fn t_eq_str(ctx: *TestCtx, got: []u8, want: []u8, name: []u8) void {
    ctx.*.total = ctx.*.total + 1;
    if (@strEq(got, want)) {
        _zag_print("PASS ");
        _zag_println(name);
    } else {
        ctx.*.failures = ctx.*.failures + 1;
        _zag_print("FAIL ");
        _zag_print(name);
        _zag_print("  got=");
        _zag_print(got);
        _zag_print("  want=");
        _zag_println(want);
    }
}

// Decode a lowercase/uppercase hex string into a freshly malloc'd byte slice.
fn x25test_hex_to_bytes(hex: []u8) []u8 {
    let n: i32 = hex.len / 2;
    let raw: *i8 = _zag_malloc(n);
    let out: *u8 = raw as *u8;
    let i: i32 = 0;
    while (i < n) {
        let hi: i32 = str_hex_val(hex[i * 2]);
        let lo: i32 = str_hex_val(hex[i * 2 + 1]);
        out[i] = ((hi << 4) | lo) as u8;
        i = i + 1;
    }
    return out[0..n];
}

fn main() i32 {
    let ctx: TestCtx = TestCtx{ .failures = 0, .total = 0 };
    let pc: *TestCtx = &ctx;

    // ── RFC 7748 §5.2 test vector 1 ─────────────────────────────────────
    let s1: []u8 = x25test_hex_to_bytes("a546e36bf0527c9d3b16154b82465edd62144c0ac1fc5a18506a2244ba449ac4");
    let u1: []u8 = x25test_hex_to_bytes("e6db6867583030db3594c1a424b15f7c726624ec26b3353b10a903a6d0ab1c4c");
    let want1: []u8 = "c3da55379de9c6908e94ea4df28d084f32eccf03491c71f754b4075577a28552";
    let got1: []u8 = str_to_hex(x25519(s1, u1));
    t_eq_str(pc, got1, want1, "RFC7748 5.2 vector 1");

    // ── RFC 7748 §5.2 test vector 2 ─────────────────────────────────────
    let s2: []u8 = x25test_hex_to_bytes("4b66e9d4d1b4673c5ad22691957d6af5c11b6421e0ea01d42ca4169e7918ba0d");
    let u2: []u8 = x25test_hex_to_bytes("e5210f12786811d3f4b7959d0538ae2c31dbe7106fc03c3efc4cd549c715a493");
    let want2: []u8 = "95cbde9476e8907d7aade45cb4b873f88b595a68799fa152e6f8f7647aac7957";
    let got2: []u8 = str_to_hex(x25519(s2, u2));
    t_eq_str(pc, got2, want2, "RFC7748 5.2 vector 2");

    // ── RFC 7748 §6.1 Diffie-Hellman round trip ─────────────────────────
    let a_priv: []u8 = x25test_hex_to_bytes("77076d0a7318a57d3c16c17251b26645df4c2f87ebc0992ab177fba51db92c2a");
    let a_pub_want: []u8 = "8520f0098930a754748b7ddcb43ef75a0dbf3a0d26381af4eba4a98eaa9b4e6a";
    let b_priv: []u8 = x25test_hex_to_bytes("5dab087e624a8a4b79e17f8b83800ee66f3bb1292618b6fd1c2f8b27ff88e0eb");
    let b_pub_want: []u8 = "de9edb7d7b7dc1b4d35b61c2ece435373f8343c85b78674dadfc7e146f882b4f";
    let shared_want: []u8 = "4a5d9d5ba4ce2de1728e3bf480350f25e07e21c947d19e3376f09b3c1e161742";

    let a_pub: []u8 = x25519_base(a_priv);
    let a_pub_hex: []u8 = str_to_hex(a_pub);
    t_eq_str(pc, a_pub_hex, a_pub_want, "RFC7748 6.1 Alice public = x25519_base(a)");

    let b_pub: []u8 = x25519_base(b_priv);
    let b_pub_hex: []u8 = str_to_hex(b_pub);
    t_eq_str(pc, b_pub_hex, b_pub_want, "RFC7748 6.1 Bob public = x25519_base(b)");

    let shared_a: []u8 = str_to_hex(x25519(a_priv, b_pub));
    t_eq_str(pc, shared_a, shared_want, "RFC7748 6.1 shared secret via x25519(a, BobPub)");

    let shared_b: []u8 = str_to_hex(x25519(b_priv, a_pub));
    t_eq_str(pc, shared_b, shared_want, "RFC7748 6.1 shared secret via x25519(b, AlicePub)");

    _zag_println("");
    _zag_print(_zag_i64_to_str((ctx.total - ctx.failures) as i64));
    _zag_print("/");
    _zag_print(_zag_i64_to_str(ctx.total as i64));
    _zag_println(" checks passed");
    if (ctx.failures > 0) {
        _zag_print("FAILURES: ");
        _zag_println(_zag_i64_to_str(ctx.failures as i64));
        return 1;
    }
    _zag_println("ALL PASS");
    return 0;
}

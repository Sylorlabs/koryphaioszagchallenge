// Focused deterministic tests for strict DER/X.509 leaf handling.
// Build/run:
//   toolchain/zag/zag-poc/znc probe/x509test.zag -o build/x509test --analyze-strict --run

@import("../src/zrt/x509.zag")
@import("../src/zrt/str.zag")

struct X509TestCtx { total: i32, failed: i32 }

fn x509t_ok(ctx: *X509TestCtx, cond: bool, name: []u8) void {
    ctx.*.total = ctx.*.total + 1;
    if (cond) { _zag_print("PASS "); _zag_println(name); }
    else { ctx.*.failed = ctx.*.failed + 1; _zag_print("FAIL "); _zag_println(name); }
}

fn x509t_bytes(out: *ArrayList[u8], value: []u8) void {
    let i: i32 = 0;
    while (i < value.len) { push[u8](out, value[i]); i = i + 1; }
}

fn x509t_wrap(tag: i32, body: []u8) []u8 {
    let out: ArrayList[u8] = make[u8](body.len + 4);
    push[u8](&out, tag as u8);
    if (body.len < 128) {
        push[u8](&out, body.len as u8);
    } else if (body.len < 256) {
        push[u8](&out, 129);
        push[u8](&out, body.len as u8);
    } else {
        push[u8](&out, 130);
        push[u8](&out, ((body.len >> 8) & 255) as u8);
        push[u8](&out, (body.len & 255) as u8);
    }
    x509t_bytes(&out, body);
    return out.data[0..out.len];
}

fn x509t_append(out: *ArrayList[u8], value: []u8) void { x509t_bytes(out, value); }

fn x509t_u24(out: *ArrayList[u8], value: i32) void {
    push[u8](out, ((value >> 16) & 255) as u8);
    push[u8](out, ((value >> 8) & 255) as u8);
    push[u8](out, (value & 255) as u8);
}

fn x509t_tls_cert_message(cert: []u8) []u8 {
    let body: ArrayList[u8] = make[u8](cert.len + 12);
    push[u8](&body, 0); // empty certificate_request_context
    x509t_u24(&body, cert.len + 5);
    x509t_u24(&body, cert.len);
    x509t_append(&body, cert);
    push[u8](&body, 0); push[u8](&body, 0); // empty per-entry extensions
    let out: ArrayList[u8] = make[u8](body.len + 4);
    push[u8](&out, 11);
    x509t_u24(&out, body.len);
    x509t_append(&out, body.data[0..body.len]);
    return out.data[0..out.len];
}

fn x509t_cert(dns: []u8, not_before: []u8, not_after: []u8, include_san: bool) []u8 {
    let validity_body: ArrayList[u8] = make[u8](40);
    x509t_append(&validity_body, x509t_wrap(23, not_before));
    x509t_append(&validity_body, x509t_wrap(23, not_after));
    let validity: []u8 = x509t_wrap(48, validity_body.data[0..validity_body.len]);

    let optional_extensions: []u8 = "";
    if (include_san) {
        let names_body: ArrayList[u8] = make[u8](dns.len + 4);
        x509t_append(&names_body, x509t_wrap(130, dns));
        let names: []u8 = x509t_wrap(48, names_body.data[0..names_body.len]);
        let ext_body: ArrayList[u8] = make[u8](names.len + 12);
        x509t_append(&ext_body, x509t_wrap(6, "\x55\x1d\x11"));
        x509t_append(&ext_body, x509t_wrap(4, names));
        let ext: []u8 = x509t_wrap(48, ext_body.data[0..ext_body.len]);
        let exts_body: ArrayList[u8] = make[u8](ext.len);
        x509t_append(&exts_body, ext);
        let exts: []u8 = x509t_wrap(48, exts_body.data[0..exts_body.len]);
        optional_extensions = x509t_wrap(163, exts);
    }

    let tbs_body: ArrayList[u8] = make[u8](160);
    x509t_append(&tbs_body, x509t_wrap(160, "\x02\x01\x02"));
    x509t_append(&tbs_body, "\x02\x01\x01");
    x509t_append(&tbs_body, "\x30\x00");
    x509t_append(&tbs_body, "\x30\x00");
    x509t_append(&tbs_body, validity);
    x509t_append(&tbs_body, "\x30\x00");
    x509t_append(&tbs_body, "\x30\x00");
    x509t_append(&tbs_body, optional_extensions);
    let tbs: []u8 = x509t_wrap(48, tbs_body.data[0..tbs_body.len]);

    let cert_body: ArrayList[u8] = make[u8](tbs.len + 12);
    x509t_append(&cert_body, tbs);
    x509t_append(&cert_body, "\x30\x00");
    x509t_append(&cert_body, "\x03\x02\x00\x01");
    return x509t_wrap(48, cert_body.data[0..cert_body.len]);
}

fn main() i32 {
    let ctx: X509TestCtx = X509TestCtx{ .total = 0, .failed = 0 };
    // 2026-01-01T00:00:00Z .. 2027-01-01T00:00:00Z
    let cert: []u8 = x509t_cert("api.example.com", "260101000000Z", "270101000000Z", true);
    let leaf: X509Leaf = x509_parse_leaf(cert);
    x509t_ok(&ctx, leaf.ok, "strict synthetic certificate parses");
    x509t_ok(&ctx, leaf.not_before == 1767225600, "UTCTime notBefore converts exactly");
    x509t_ok(&ctx, leaf.not_after == 1798761600, "UTCTime notAfter converts exactly");
    let good: X509Check = x509_check_leaf(cert, "API.EXAMPLE.COM", 1780000000);
    x509t_ok(&ctx, good.der_ok && good.hostname_ok && good.time_ok, "leaf syntax hostname and time preflight passes");
    x509t_ok(&ctx, !good.chain_ok && !good.signature_ok && !good.ok, "preflight never claims authentication");
    x509t_ok(&ctx, !x509_validate_server(cert, "api.example.com", 1780000000), "full validation fails closed without trust chain");

    let wrong: X509Check = x509_check_leaf(cert, "evil.example.com", 1780000000);
    x509t_ok(&ctx, !wrong.hostname_ok, "wrong hostname rejected");
    let expired: X509Check = x509_check_leaf(cert, "api.example.com", 1800000000);
    x509t_ok(&ctx, !expired.time_ok, "expired certificate rejected");
    let early: X509Check = x509_check_leaf(cert, "api.example.com", 1700000000);
    x509t_ok(&ctx, !early.time_ok, "not-yet-valid certificate rejected");

    let wild: []u8 = x509t_cert("*.example.com", "260101000000Z", "270101000000Z", true);
    x509t_ok(&ctx, x509_check_leaf(wild, "api.example.com", 1780000000).hostname_ok, "single-label wildcard matches");
    x509t_ok(&ctx, !x509_check_leaf(wild, "a.b.example.com", 1780000000).hostname_ok, "wildcard cannot span labels");
    x509t_ok(&ctx, !x509_check_leaf(wild, "example.com", 1780000000).hostname_ok, "wildcard requires a label");

    let no_san: []u8 = x509t_cert("api.example.com", "260101000000Z", "270101000000Z", false);
    x509t_ok(&ctx, !x509_parse_leaf(no_san).ok, "missing SAN rejected without CN fallback");
    let bad_date: []u8 = x509t_cert("api.example.com", "260231000000Z", "270101000000Z", true);
    x509t_ok(&ctx, !x509_parse_leaf(bad_date).ok, "invalid calendar date rejected");
    let nul_san: []u8 = x509t_cert("api\x00.example.com", "260101000000Z", "270101000000Z", true);
    x509t_ok(&ctx, !x509_parse_leaf(nul_san).ok, "embedded NUL in dNSName rejected");

    let malformed: []u8 = "\x30\x80\x00\x00";
    x509t_ok(&ctx, !x509_parse_leaf(malformed).ok, "BER indefinite length rejected");
    let nonminimal: []u8 = "\x30\x81\x01\x00";
    x509t_ok(&ctx, !x509_parse_leaf(nonminimal).ok, "non-minimal DER length rejected");
    x509t_ok(&ctx, !x509_parse_leaf(cert[0..cert.len - 1]).ok, "truncated certificate rejected");

    let tls_message: []u8 = x509t_tls_cert_message(cert);
    let extracted: ?[]u8 = x509_tls13_leaf(tls_message);
    if (extracted) |leaf_der| {
        x509t_ok(&ctx, leaf_der.len == cert.len && x509_parse_leaf(leaf_der).ok, "TLS 1.3 Certificate leaf extracted");
    } else { x509t_ok(&ctx, false, "TLS 1.3 Certificate leaf extracted"); }
    let truncated_tls: ?[]u8 = x509_tls13_leaf(tls_message[0..tls_message.len - 1]);
    if (truncated_tls) |_| { x509t_ok(&ctx, false, "truncated TLS Certificate rejected"); }
    else { x509t_ok(&ctx, true, "truncated TLS Certificate rejected"); }

    _zag_print("X509 TESTS: ");
    _zag_print(_zag_i64_to_str(ctx.total as i64));
    _zag_print(" checks, ");
    _zag_print(_zag_i64_to_str(ctx.failed as i64));
    _zag_println(" failed");
    if (ctx.failed == 0) { return 0; }
    return 1;
}

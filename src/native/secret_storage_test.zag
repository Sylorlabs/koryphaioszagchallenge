@import("secret_service.zag")
@import("encrypted_vault.zag")

fn check(name_: []u8, ok: bool, failures: *i32) void {
    if (ok) { _zag_print("  ok  "); } else { _zag_print("  XX  "); failures.* = failures.* + 1; }
    _zag_println(name_);
}

fn fixed_bytes(n: i32, seed: i32) []u8 {
    let raw: *i8 = _zag_malloc(n);
    let out: *u8 = raw as *u8;
    let i: i32 = 0;
    while (i < n) { out[i] = ((seed + i) & 255) as u8; i = i + 1; }
    return out[0..n];
}

fn file_mode(path: []u8) i64 {
    let stat_raw: *i8 = _zag_malloc(144);
    let cpath: *i8 = util_cpath(path);
    let rc: i64 = _zag_raw_syscall(4, cpath as i64, stat_raw as i64, 0, 0, 0, 0);
    _zag_free(cpath);
    if (rc != 0) { _zag_free(stat_raw); return 0 - 1; }
    let stat_bytes: []u8 = (stat_raw as *u8)[0..144];
    let mode: i64 = vault_u32_at(stat_bytes, 24) & 4095;
    _zag_free(stat_raw);
    return mode;
}

fn main() i32 {
    let failures: i32 = 0;
    let client: SecretServiceClient = secret_service_client();
    check("Secret Service starts disconnected and credential-ineligible",
        !ss_is_credential_ready(&client) &&
        secret_storage_select(&client, "") == SecretStorageBackend.unavailable, &failures);
    check("D-Bus authentication alone never authorizes credential traffic",
        ss_transition(&client, SecretServiceState.dbus_auth_pending) &&
        ss_transition(&client, SecretServiceState.dbus_authenticated) &&
        secret_storage_select(&client, "") == SecretStorageBackend.unavailable, &failures);
    check("invalid Secret Service state transition fails closed with a stable code",
        !ss_transition(&client, SecretServiceState.service_discovered) &&
        client.state == SecretServiceState.protocol_error &&
        str_eq(client.error_code, "E_SECRET_SERVICE_STATE"), &failures);

    let auth: []u8 = ss_encode_external_auth("1000");
    check("D-Bus EXTERNAL auth encodes ASCII uid as hexadecimal",
        str_eq(auth, "\0AUTH EXTERNAL 31303030\r\n"), &failures);
    check("session bus parser accepts one unambiguous filesystem socket only",
        str_eq(ss_session_bus_path("unix:path=/run/user/1000/bus"), "/run/user/1000/bus") &&
        ss_session_bus_path("unix:abstract=/tmp/dbus-x").len == 0 &&
        ss_session_bus_path("unix:path=/tmp/a;unix:path=/tmp/b").len == 0, &failures);
    let hello: []u8 = ss_encode_hello(7);
    check("D-Bus Hello encoder emits little-endian method call with serial",
        hello.len > 96 && hello[0] == ('l' as u8) && hello[1] == 1 as u8 &&
        hello[4] == 0 as u8 && hello[8] == 7 as u8 &&
        str_index_of(hello, "org.freedesktop.DBus") >= 0 && str_index_of(hello, "Hello") >= 0,
        &failures);
    let dh: []u8 = fixed_bytes(128, 1);
    let open_session: []u8 = ss_encode_open_encrypted_session(8, dh);
    check("OpenSession encoder requests encrypted DH mode rather than plain mode",
        str_index_of(open_session, "dh-ietf1024-sha256-aes128-cbc-pkcs7") >= 0 &&
        str_index_of(open_session, "OpenSession") >= 0 && str_index_of(open_session, "plain") < 0,
        &failures);

    let key: []u8 = fixed_bytes(32, 17);
    let wrong_key: []u8 = fixed_bytes(32, 18);
    let nonce: []u8 = fixed_bytes(12, 90);
    let sealed: VaultResult = vault_seal_with_nonce(key, nonce, "provider:openai", "credential-value");
    let opened: VaultResult = vault_open(key, "provider:openai", sealed.data);
    check("explicit-key vault round-trips with ChaCha20-Poly1305",
        sealed.status == VaultStatus.ok && opened.status == VaultStatus.ok &&
        str_eq(opened.data, "credential-value") && str_index_of(sealed.data, "credential-value") < 0,
        &failures);
    check("vault rejects wrong keys without exposing plaintext",
        vault_open(wrong_key, "provider:openai", sealed.data).status == VaultStatus.authentication_failed &&
        vault_open(wrong_key, "provider:openai", sealed.data).data.len == 0, &failures);
    check("vault binds ciphertext to provider scope",
        vault_open(key, "provider:anthropic", sealed.data).status == VaultStatus.authentication_failed,
        &failures);
    let tampered: []u8 = fixed_bytes(sealed.data.len, 0);
    let i: i32 = 0;
    while (i < sealed.data.len) { tampered[i] = sealed.data[i]; i = i + 1; }
    tampered[tampered.len - 1] = tampered[tampered.len - 1] ^ (1 as u8);
    check("vault rejects tampering and malformed length",
        vault_open(key, "provider:openai", tampered).status == VaultStatus.authentication_failed &&
        vault_open(key, "provider:openai", "KPV1").status == VaultStatus.malformed, &failures);
    check("vault rejects passwords and short keys instead of inventing a weak KDF",
        vault_seal_with_nonce("password", nonce, "provider:openai", "secret").status == VaultStatus.invalid_key &&
        secret_storage_select(&client, "password") == SecretStorageBackend.unavailable, &failures);
    let random_a: VaultResult = vault_seal(key, "provider:openai", "same-secret");
    let random_b: VaultResult = vault_seal(key, "provider:openai", "same-secret");
    check("vault obtains a fresh kernel nonce for every seal",
        random_a.status == VaultStatus.ok && random_b.status == VaultStatus.ok &&
        !str_eq(random_a.data, random_b.data), &failures);
    let fallback: SecretServiceClient = secret_service_client();
    check("explicit 256-bit key enables encrypted-vault fallback",
        secret_storage_select(&fallback, key) == SecretStorageBackend.encrypted_vault, &failures);

    let root: []u8 = _zag_str_concat("/tmp/koryphaios-vault-test-", _zag_i64_to_str(util_getpid()));
    util_mkdir(root);
    let path: []u8 = _zag_str_concat(root, "/credentials.kpv");
    let write_status: VaultStatus = vault_write(path, key, "provider:openai", "persisted-secret");
    let persisted: VaultResult = vault_read(path, key, "provider:openai");
    check("vault persists only authenticated ciphertext in mode 0600 file",
        write_status == VaultStatus.ok && persisted.status == VaultStatus.ok &&
        str_eq(persisted.data, "persisted-secret") &&
        str_index_of(util_read_or_empty(path), "persisted-secret") < 0 && file_mode(path) == 384,
        &failures);

    if (failures == 0) { _zag_println("SECRET STORAGE: ALL PASS"); return 0; }
    _zag_println("SECRET STORAGE: FAILURES"); return 1;
}

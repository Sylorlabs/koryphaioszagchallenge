// In-process application core. UI code submits AppCommand values and consumes
// AppEvent values; no UI action crosses an HTTP or WebSocket boundary.

@import("contract.zag")
@import("../backend/store.zag")
@import("provider_codex.zag")

struct ProviderIdentity {
    id: []u8,
    name_: []u8,
    transport: []u8,
    executable: []u8,
    detected_path: []u8,
    available: bool,
    authenticated: bool,
}

struct CliRun {
    pid: i64,
    session_id: []u8,
    provider_id: []u8,
    output_path: []u8,
    seen_bytes: i32,
    pending_line: []u8,
    assistant_text: []u8,
    last_snapshot: []u8,
    cancelled: bool,
    timed_out: bool,
    started_ms: i64,
}

struct AppCore {
    store: *Store,
    active_session_id: []u8,
    providers: ArrayList[*ProviderIdentity],
    events: ArrayList[*AppEvent],
    data_dir: []u8,
    always_create_session: bool,
    test_provider_enabled: bool,
    selected_provider_id: []u8,
    cli_run: ?*CliRun,
    codex_run: ?*CodexRun,
    codex_auth_run: ?*CodexAuthRun,
    codex_session_id: []u8,
    codex_event_seen: i32,
    codex_assistant_text: []u8,
    codex_input_tokens: i64,
    codex_output_tokens: i64,
    codex_usage_known: bool,
    codex_started_ms: i64,
    codex_timed_out: bool,
    memory_text: []u8,
    rules_text: []u8,
    ready: bool,
    error_code: []u8,
}

fn core_event(core: *AppCore, kind: AppEventKind, sid: []u8, payload: []u8, code: []u8) void {
    push[*AppEvent](&core.*.events, new(AppEvent{
        .kind = kind,
        .session_id = _zag_strdup(sid),
        .payload = _zag_strdup(payload),
        .code = code,
    }));
}

fn core_add_provider(core: *AppCore, id: []u8, name_: []u8, transport: []u8, executable: []u8) void {
    push[*ProviderIdentity](&core.*.providers, new(ProviderIdentity{
        .id = id,
        .name_ = name_,
        .transport = transport,
        .executable = executable,
        .detected_path = "",
        .available = false,
        .authenticated = false,
    }));
}

fn core_provider_catalog(core: *AppCore) void {
    core_add_provider(core, "google-ai-studio", "Google AI Studio", "api", "");
    core_add_provider(core, "google-api", "Google API", "api", "");
    core_add_provider(core, "vertex-ai", "Vertex AI", "api", "");
    core_add_provider(core, "jules", "Jules", "cli", "jules");
    core_add_provider(core, "gemini-cli", "Gemini CLI", "cli", "gemini");
    core_add_provider(core, "codex", "Codex", "cli", "codex");
    core_add_provider(core, "claude-code", "Claude Code", "cli", "claude");
    core_add_provider(core, "cursor", "Cursor", "cli", "cursor-agent");
    core_add_provider(core, "cline", "Cline", "cli", "cline");
    core_add_provider(core, "openai", "OpenAI", "api", "");
    core_add_provider(core, "anthropic", "Anthropic", "api", "");
    core_add_provider(core, "ollama", "Ollama", "local", "");
}

fn core_path_executable(path: []u8) bool {
    let cpath: *i8 = util_cpath(path);
    let rc: i64 = _zag_raw_syscall(21, cpath as i64, 1, 0, 0, 0, 0);
    _zag_free(cpath);
    return rc == 0;
}

fn core_find_executable_in_path(executable: []u8, path_env: []u8) []u8 {
    if (executable.len == 0 || path_env.len == 0) { return ""; }
    let remaining: []u8 = path_env;
    let searching: bool = true;
    while (searching) {
        let part: SplitResult = str_split_first(remaining, ':' as u8);
        // Empty PATH entries mean the current directory. Ignore them so a
        // project cannot impersonate a provider CLI.
        if (part.head.len > 0) {
            let candidate: []u8 = _zag_str_concat(part.head, _zag_str_concat("/", executable));
            if (core_path_executable(candidate)) { return candidate; }
        }
        if (!part.found) { searching = false; } else { remaining = part.tail; }
    }
    return "";
}

fn core_cline_authenticated(home: []u8) bool {
    if (home.len == 0) { return false; }
    let raw: []u8 = util_read_or_empty(_zag_str_concat(home, "/.cline/data/secrets.json"));
    if (raw.len == 0) { return false; }
    if (json_parse(raw)) |node| {
        switch (node.*) {
            .obj => |entries| {
                let i: i32 = 0;
                while (i < entries.len) {
                    if (json_str(get[JEntry](entries, i).val).len > 0) { return true; }
                    i = i + 1;
                }
            }
            else => { }
        }
    }
    return false;
}

fn core_refresh_providers(core: *AppCore, path_env: []u8) i32 {
    let found: i32 = 0;
    let i: i32 = 0;
    while (i < core.*.providers.len) {
        let provider: *ProviderIdentity = get[*ProviderIdentity](core.*.providers, i);
        provider.*.available = false;
        provider.*.authenticated = false;
        provider.*.detected_path = "";
        if (str_eq(provider.*.transport, "cli") && provider.*.executable.len > 0) {
            let path: []u8 = core_find_executable_in_path(provider.*.executable, path_env);
            if (path.len > 0) {
                provider.*.available = true;
                provider.*.detected_path = path;
                if (str_eq(provider.*.id, "cline")) {
                    provider.*.authenticated = core_cline_authenticated(_zag_getenv("HOME"));
                } else if (str_eq(provider.*.id, "codex") && !core.*.test_provider_enabled && core.*.codex_auth_run == null) {
                    let nonce: []u8 = util_nanoid(8);
                    let auth_out: []u8 = _zag_str_concat(core.*.data_dir, _zag_str_concat("/codex-auth-", _zag_str_concat(nonce, ".out")));
                    let auth_err: []u8 = _zag_str_concat(core.*.data_dir, _zag_str_concat("/codex-auth-", _zag_str_concat(nonce, ".err")));
                    core.*.codex_auth_run = codex_spawn_auth_status(path, auth_out, auth_err);
                }
                found = found + 1;
            }
        }
        i = i + 1;
    }
    core_event(core, AppEventKind.provider_changed, "", _zag_i64_to_str(found as i64), "");
    return found;
}

fn core_schema_path(core: *AppCore) []u8 {
    return _zag_str_concat(core.*.data_dir, "/native-schema.json");
}

fn core_schema_backup_path(core: *AppCore) []u8 {
    return _zag_str_concat(core.*.data_dir, "/native-schema.corrupt.backup");
}

fn core_settings_path(core: *AppCore) []u8 {
    return _zag_str_concat(core.*.data_dir, "/native-settings.json");
}

fn core_settings_backup_path(core: *AppCore) []u8 {
    return _zag_str_concat(core.*.data_dir, "/native-settings.corrupt.backup");
}

fn core_memory_path(core: *AppCore) []u8 {
    return _zag_str_concat(core.*.data_dir, "/memory/PROJECT.md");
}

fn core_rules_path(core: *AppCore) []u8 {
    return _zag_str_concat(core.*.data_dir, "/rules/PROJECT.md");
}

fn core_load_knowledge(core: *AppCore) void {
    util_mkdir(_zag_str_concat(core.*.data_dir, "/memory"));
    util_mkdir(_zag_str_concat(core.*.data_dir, "/rules"));
    core.*.memory_text = util_read_or_empty(core_memory_path(core));
    core.*.rules_text = util_read_or_empty(core_rules_path(core));
}

fn core_save_settings(core: *AppCore) bool {
    let value: []u8 = "false";
    if (core.*.always_create_session) { value = "true"; }
    return util_write_atomic(core_settings_path(core),
        _zag_str_concat("{\"schemaVersion\":1,\"alwaysCreateSession\":", _zag_str_concat(value,
            _zag_str_concat(",\"selectedProvider\":\"", _zag_str_concat(str_escape_json(core.*.selected_provider_id), "\"}")))));
}

fn core_load_settings(core: *AppCore) bool {
    let path: []u8 = core_settings_path(core);
    let raw: []u8 = util_read_or_empty(path);
    if (raw.len == 0) {
        core.*.always_create_session = false;
        return core_save_settings(core);
    }
    let parsed: ?*JNode = json_parse(raw);
    if (parsed) |node| {
        if (json_int(json_get(node, "schemaVersion")) == 1) {
            core.*.always_create_session = json_bool(json_get(node, "alwaysCreateSession"));
            let selected: []u8 = json_str(json_get(node, "selectedProvider"));
            if (selected.len == 0) { core.*.selected_provider_id = ""; }
            else if (core_find_provider(core, selected)) |_provider| { core.*.selected_provider_id = _zag_strdup(selected); }
            return true;
        }
    }
    util_write_atomic(core_settings_backup_path(core), raw);
    return false;
}

fn core_check_schema(core: *AppCore) bool {
    let path: []u8 = core_schema_path(core);
    let raw: []u8 = util_read_or_empty(path);
    if (raw.len == 0) {
        return util_write_atomic(path, "{\"schemaVersion\":1,\"format\":\"koryphaios-native\"}");
    }
    let parsed: ?*JNode = json_parse(raw);
    if (parsed) |node| {
        if (json_int(json_get(node, "schemaVersion")) == 1 &&
            str_eq(json_str(json_get(node, "format")), "koryphaios-native")) {
            return true;
        }
    }
    util_write_atomic(core_schema_backup_path(core), raw);
    return false;
}

fn core_open_mode(data_dir: []u8, test_provider_enabled: bool) *AppCore {
    let core: *AppCore = new(AppCore{
        .store = store_open(data_dir),
        .active_session_id = "",
        .providers = make[*ProviderIdentity](16),
        .events = make[*AppEvent](16),
        .data_dir = _zag_strdup(data_dir),
        .always_create_session = false,
        .test_provider_enabled = test_provider_enabled,
        .selected_provider_id = "",
        .cli_run = null,
        .codex_run = null,
        .codex_auth_run = null,
        .codex_session_id = "",
        .codex_event_seen = 0,
        .codex_assistant_text = "",
        .codex_input_tokens = 0,
        .codex_output_tokens = 0,
        .codex_usage_known = false,
        .codex_started_ms = 0,
        .codex_timed_out = false,
        .memory_text = "",
        .rules_text = "",
        .ready = false,
        .error_code = "",
    });
    core_provider_catalog(core);
    if (!core_check_schema(core)) {
        core.*.error_code = "E_STORAGE_SCHEMA";
        core_event(core, AppEventKind.recovery_required, "", "Native schema is invalid; the original was backed up.", core.*.error_code);
        return core;
    }
    if (!core_load_settings(core)) {
        core.*.error_code = "E_SETTINGS_SCHEMA";
        core_event(core, AppEventKind.recovery_required, "", "Native settings are invalid; the original was backed up.", core.*.error_code);
        return core;
    }
    core_load_knowledge(core);
    if (core.*.store.*.sessions.len > 0) {
        core.*.active_session_id = get[*Session](core.*.store.*.sessions, 0).*.id;
    }
    core.*.ready = true;
    core_event(core, AppEventKind.startup_ready, core.*.active_session_id, "storage, catalog, project, and UI resources ready", "");
    return core;
}

fn core_open(data_dir: []u8) *AppCore {
    return core_open_mode(data_dir, false);
}

fn core_open_test(data_dir: []u8) *AppCore {
    return core_open_mode(data_dir, true);
}

fn core_find_provider(core: *AppCore, id: []u8) ?*ProviderIdentity {
    let i: i32 = 0;
    while (i < core.*.providers.len) {
        let p: *ProviderIdentity = get[*ProviderIdentity](core.*.providers, i);
        if (str_eq(p.*.id, id)) { return p; }
        i = i + 1;
    }
    return null;
}

fn core_reject(core: *AppCore, cmd: *AppCommand, code: []u8, message: []u8) bool {
    core_event(core, AppEventKind.command_rejected, cmd.*.session_id, message, code);
    return false;
}

fn core_cline_line(core: *AppCore, run: *CliRun, line: []u8) void {
    let parsed: ?*JNode = json_parse(str_trim(line));
    if (parsed) |node| {
        let kind: []u8 = json_str(json_get(node, "type"));
        let say: []u8 = json_str(json_get(node, "say"));
        let text_: []u8 = json_str(json_get(node, "text"));
        if (str_eq(kind, "say") && (str_eq(say, "text") || str_eq(say, "completion_result")) && text_.len > 0) {
            let delta: []u8 = text_;
            if (str_starts_with(text_, run.*.last_snapshot)) { delta = text_[run.*.last_snapshot.len..]; }
            run.*.last_snapshot = _zag_strdup(text_);
            if (delta.len > 0) {
                run.*.assistant_text = _zag_str_concat(run.*.assistant_text, delta);
                core_event(core, AppEventKind.stream_delta, run.*.session_id, delta, "");
            }
        } else if (str_eq(kind, "say") && str_eq(say, "reasoning")) {
            core_event(core, AppEventKind.agent_status, run.*.session_id, "thinking", "");
        } else if (str_eq(kind, "error") && text_.len > 0) {
            core_event(core, AppEventKind.command_rejected, run.*.session_id, text_, "E_PROVIDER_STREAM");
        }
    }
}

fn core_cline_ingest(core: *AppCore, run: *CliRun, raw: []u8) void {
    if (raw.len <= run.*.seen_bytes) { return; }
    let chunk: []u8 = _zag_str_concat(run.*.pending_line, raw[run.*.seen_bytes..]);
    run.*.seen_bytes = raw.len;
    run.*.pending_line = "";
    let rest: []u8 = chunk;
    let parsing: bool = true;
    while (parsing) {
        let part: SplitResult = str_split_first(rest, '\n' as u8);
        if (!part.found) { run.*.pending_line = _zag_strdup(rest); parsing = false; }
        else { core_cline_line(core, run, part.head); rest = part.tail; }
    }
}

fn core_finish_cli(core: *AppCore, run: *CliRun, exit_code: i32, raw: []u8) void {
    if (run.*.timed_out) {
        core_event(core, AppEventKind.command_rejected, run.*.session_id, "Cline exceeded the 300 second turn limit.", "E_PROVIDER_TIMEOUT");
        core_event(core, AppEventKind.agent_status, run.*.session_id, "error", "");
    } else if (run.*.cancelled) {
        if (run.*.assistant_text.len > 0) {
            run.*.assistant_text = _zag_str_concat(run.*.assistant_text, "\n\nStopped by user.");
        }
        core_event(core, AppEventKind.agent_status, run.*.session_id, "cancelled", "");
    } else if (exit_code != 0 && run.*.assistant_text.len == 0) {
        let detail: []u8 = str_trim(raw);
        if (detail.len == 0) { detail = _zag_str_concat("Cline exited with status ", _zag_i64_to_str(exit_code as i64)); }
        if (detail.len > 300) { detail = detail[0..300]; }
        core_event(core, AppEventKind.command_rejected, run.*.session_id, detail, "E_PROVIDER_EXIT");
        core_event(core, AppEventKind.agent_status, run.*.session_id, "error", "");
        util_unlink(run.*.output_path);
        core.*.cli_run = null;
        return;
    }
    if (run.*.assistant_text.len > 0) {
        if (store_find(core.*.store, run.*.session_id)) |session| {
            let serialized: []u8 = message_json(util_nanoid(12), session.*.id, "assistant",
                run.*.assistant_text, "cline-default", "cline", 0, 0, 0, util_now_ms());
            store_append_message(core.*.store, session.*.id, serialized);
            session.*.message_count = session.*.message_count + 1;
            store_touch(core.*.store, session);
            core_event(core, AppEventKind.assistant_added, session.*.id, run.*.assistant_text, "");
        }
    }
    if (!run.*.cancelled && !run.*.timed_out) { core_event(core, AppEventKind.agent_status, run.*.session_id, "done", ""); }
    util_unlink(run.*.output_path);
    core.*.cli_run = null;
}

fn core_finish_codex(core: *AppCore, run: *CodexRun) void {
    let sid: []u8 = core.*.codex_session_id;
    if (core.*.codex_timed_out) {
        core_event(core, AppEventKind.command_rejected, sid, "Codex exceeded the 300 second turn limit.", "E_PROVIDER_TIMEOUT");
        core_event(core, AppEventKind.agent_status, sid, "error", "");
    } else if (run.*.cancelled) {
        if (core.*.codex_assistant_text.len > 0) {
            core.*.codex_assistant_text = _zag_str_concat(core.*.codex_assistant_text, "\n\nStopped by user.");
        }
        core_event(core, AppEventKind.agent_status, sid, "cancelled", "");
    } else if (run.*.exit_code != 0 && core.*.codex_assistant_text.len == 0) {
        core_event(core, AppEventKind.command_rejected, sid,
            _zag_str_concat("Codex exited with status ", _zag_i64_to_str(run.*.exit_code as i64)), "E_PROVIDER_EXIT");
        core_event(core, AppEventKind.agent_status, sid, "error", "");
    }
    if (core.*.codex_assistant_text.len > 0) {
        if (store_find(core.*.store, sid)) |session| {
            let input_tokens: i64 = 0;
            let output_tokens: i64 = 0;
            if (core.*.codex_usage_known) {
                input_tokens = core.*.codex_input_tokens;
                output_tokens = core.*.codex_output_tokens;
            }
            let serialized: []u8 = message_json(util_nanoid(12), session.*.id, "assistant",
                core.*.codex_assistant_text, "codex-cli", "codex", input_tokens, output_tokens, 0, util_now_ms());
            store_append_message(core.*.store, session.*.id, serialized);
            session.*.message_count = session.*.message_count + 1;
            store_touch(core.*.store, session);
            core_event(core, AppEventKind.assistant_added, session.*.id, core.*.codex_assistant_text, "");
        }
    }
    if (!run.*.cancelled && !core.*.codex_timed_out && run.*.exit_code == 0) {
        core_event(core, AppEventKind.agent_status, sid, "done", "");
    }
    util_unlink(run.*.stdout_path);
    util_unlink(run.*.stderr_path);
    core.*.codex_run = null;
    core.*.codex_session_id = "";
}

fn core_tick(core: *AppCore) void {
    if (core.*.codex_auth_run) |auth| {
        codex_auth_tick(auth);
        if (auth.*.finished) {
            if (core_find_provider(core, "codex")) |provider| { provider.*.authenticated = auth.*.authenticated; }
            core_event(core, AppEventKind.provider_changed, "", "codex-auth-refreshed", "");
            util_unlink(auth.*.stdout_path);
            util_unlink(auth.*.stderr_path);
            core.*.codex_auth_run = null;
        }
    }
    if (core.*.cli_run) |run| {
        if (!run.*.cancelled && !run.*.timed_out && util_now_ms() - run.*.started_ms > 300000) {
            run.*.timed_out = true;
            util_kill_child(run.*.pid);
        }
        let raw: []u8 = util_read_or_empty(run.*.output_path);
        core_cline_ingest(core, run, raw);
        let exit_code: i32 = util_poll_child(run.*.pid);
        if (exit_code >= 0) {
            // The child may append its final JSONL record immediately before
            // exit. Re-read after waitpid so completion cannot race file I/O.
            let final_raw: []u8 = util_read_or_empty(run.*.output_path);
            core_cline_ingest(core, run, final_raw);
            if (run.*.pending_line.len > 0) { core_cline_line(core, run, run.*.pending_line); }
            core_finish_cli(core, run, exit_code, final_raw);
        }
    }
    if (core.*.codex_run) |run| {
        if (!run.*.cancelled && !core.*.codex_timed_out && util_now_ms() - core.*.codex_started_ms > 300000) {
            core.*.codex_timed_out = true;
            codex_cancel(run);
        }
        codex_tick(run);
        while (core.*.codex_event_seen < run.*.events.len) {
            let event: *CodexEvent = get[*CodexEvent](run.*.events, core.*.codex_event_seen);
            core.*.codex_event_seen = core.*.codex_event_seen + 1;
            if (event.*.kind == CodexEventKind.assistant_message) {
                core.*.codex_assistant_text = _zag_str_concat(core.*.codex_assistant_text, event.*.text);
                core_event(core, AppEventKind.stream_delta, core.*.codex_session_id, event.*.text, "");
            } else if (event.*.kind == CodexEventKind.usage && event.*.usage_known) {
                core.*.codex_input_tokens = event.*.input_tokens;
                core.*.codex_output_tokens = event.*.output_tokens;
                core.*.codex_usage_known = true;
            } else if (event.*.kind == CodexEventKind.provider_activity) {
                core_event(core, AppEventKind.agent_status, core.*.codex_session_id, event.*.text, "");
            } else if (event.*.kind == CodexEventKind.provider_error) {
                core_event(core, AppEventKind.command_rejected, core.*.codex_session_id, event.*.text, "E_PROVIDER_STREAM");
            } else if (event.*.kind == CodexEventKind.stderr_text) {
                core_event(core, AppEventKind.agent_status, core.*.codex_session_id,
                    _zag_str_concat("Codex stderr: ", event.*.text), "");
            }
        }
        if (run.*.finished) { core_finish_codex(core, run); }
    }
}

fn core_cli_running(core: *AppCore) bool {
    if (core.*.cli_run) |_run| { return true; }
    if (core.*.codex_run) |_run| { return true; }
    return false;
}

fn core_can_send(core: *AppCore) bool {
    if (core.*.test_provider_enabled) { return true; }
    if (core_find_provider(core, core.*.selected_provider_id)) |provider| {
        return (str_eq(provider.*.id, "cline") || str_eq(provider.*.id, "codex")) &&
            provider.*.available && provider.*.authenticated;
    }
    return false;
}

fn core_dispatch(core: *AppCore, cmd: *AppCommand) bool {
    if (!core.*.ready && cmd.*.kind != AppCommandKind.recovery_retry) {
        return core_reject(core, cmd, "E_STARTUP_NOT_READY", "The application core is not ready.");
    }
    if (cmd.*.kind == AppCommandKind.session_new) {
        if (!cmd.*.force && !core.*.always_create_session && core.*.active_session_id.len > 0) {
            if (store_find(core.*.store, core.*.active_session_id)) |active| {
                if (active.*.message_count == 0) {
                    core_event(core, AppEventKind.session_changed, active.*.id, "reused untouched session", "");
                    return true;
                }
            }
        }
        let title: []u8 = cmd.*.payload;
        if (title.len == 0) { title = "New Session"; }
        let session: *Session = store_create_session(core.*.store, title, "");
        core.*.active_session_id = session.*.id;
        core_event(core, AppEventKind.session_changed, session.*.id, "created", "");
        return true;
    }
    if (cmd.*.kind == AppCommandKind.session_select) {
        if (store_find(core.*.store, cmd.*.session_id)) |session| {
            core.*.active_session_id = session.*.id;
            core_event(core, AppEventKind.session_changed, session.*.id, "selected", "");
            return true;
        }
        return core_reject(core, cmd, "E_SESSION_NOT_FOUND", "The selected session does not exist.");
    }
    if (cmd.*.kind == AppCommandKind.session_rename) {
        if (cmd.*.payload.len == 0) {
            return core_reject(core, cmd, "E_SESSION_TITLE_EMPTY", "A session title is required.");
        }
        if (cmd.*.payload.len > 120) {
            return core_reject(core, cmd, "E_SESSION_TITLE_LONG", "Session titles are limited to 120 bytes.");
        }
        if (!store_rename_session(core.*.store, cmd.*.session_id, cmd.*.payload)) {
            return core_reject(core, cmd, "E_SESSION_NOT_FOUND", "The session to rename does not exist.");
        }
        core_event(core, AppEventKind.session_changed, cmd.*.session_id, "renamed", "");
        return true;
    }
    if (cmd.*.kind == AppCommandKind.session_delete) {
        if (!store_delete_session(core.*.store, cmd.*.session_id)) {
            return core_reject(core, cmd, "E_SESSION_NOT_FOUND", "The session to delete does not exist.");
        }
        if (str_eq(core.*.active_session_id, cmd.*.session_id)) {
            core.*.active_session_id = "";
            if (core.*.store.*.sessions.len > 0) {
                core.*.active_session_id = get[*Session](core.*.store.*.sessions, 0).*.id;
            }
        }
        core_event(core, AppEventKind.session_deleted, core.*.active_session_id, cmd.*.session_id, "");
        return true;
    }
    if (cmd.*.kind == AppCommandKind.message_send) {
        if (cmd.*.payload.len == 0) {
            return core_reject(core, cmd, "E_MESSAGE_EMPTY", "A message is required.");
        }
        if (core.*.active_session_id.len == 0) {
            return core_reject(core, cmd, "E_SESSION_REQUIRED", "Create or select a session first.");
        }
        let cli_pid: i64 = 0 - 1;
        let cli_output: []u8 = "";
        if (!core.*.test_provider_enabled) {
            if (core.*.selected_provider_id.len == 0) {
                return core_reject(core, cmd, "E_PROVIDER_REQUIRED", "No executable model provider is selected. Open Settings and connect a provider before sending.");
            }
            if (core_cli_running(core)) { return core_reject(core, cmd, "E_PROVIDER_BUSY", "The selected provider is already running a turn."); }
            let selected: ?*ProviderIdentity = core_find_provider(core, core.*.selected_provider_id);
            if (selected) |provider| {
                if (!provider.*.available || (!str_eq(provider.*.id, "cline") && !str_eq(provider.*.id, "codex"))) {
                    return core_reject(core, cmd, "E_PROVIDER_EXECUTOR_UNAVAILABLE", "This provider does not yet have a verified native executor.");
                }
                if (str_eq(provider.*.id, "cline")) {
                    cli_output = _zag_str_concat(core.*.data_dir, _zag_str_concat("/cline-", _zag_str_concat(util_nanoid(8), ".jsonl")));
                    util_write_atomic(cli_output, "");
                    cli_pid = native_spawn_cline(provider.*.detected_path, cmd.*.payload, ".", cli_output);
                    if (cli_pid < 0) { return core_reject(core, cmd, "E_PROVIDER_SPAWN", "Cline could not be started."); }
                } else {
                    let nonce: []u8 = util_nanoid(8);
                    let stdout_path: []u8 = _zag_str_concat(core.*.data_dir, _zag_str_concat("/codex-", _zag_str_concat(nonce, ".jsonl")));
                    let stderr_path: []u8 = _zag_str_concat(core.*.data_dir, _zag_str_concat("/codex-", _zag_str_concat(nonce, ".stderr")));
                    let codex: *CodexRun = codex_spawn(provider.*.detected_path, cmd.*.payload, ".", "", stdout_path, stderr_path);
                    if (codex.*.pid < 0) { return core_reject(core, cmd, "E_PROVIDER_SPAWN", "Codex could not be started."); }
                    core.*.codex_run = codex;
                }
            } else { return core_reject(core, cmd, "E_PROVIDER_REQUIRED", "The selected provider no longer exists."); }
        }
        if (store_find(core.*.store, core.*.active_session_id)) |session| {
            let now: i64 = util_now_ms();
            let mid: []u8 = util_nanoid(12);
            let serialized: []u8 = message_json(mid, session.*.id, "user", cmd.*.payload, "", "", 0, 0, 0, now);
            store_append_message(core.*.store, session.*.id, serialized);
            session.*.message_count = session.*.message_count + 1;
            store_touch(core.*.store, session);
            core_event(core, AppEventKind.message_added, session.*.id, cmd.*.payload, "");
            if (!core.*.test_provider_enabled) {
                if (str_eq(core.*.selected_provider_id, "cline")) {
                    core.*.cli_run = new(CliRun{ .pid = cli_pid, .session_id = _zag_strdup(session.*.id),
                        .provider_id = "cline", .output_path = cli_output, .seen_bytes = 0,
                        .pending_line = "", .assistant_text = "", .last_snapshot = "", .cancelled = false,
                        .timed_out = false, .started_ms = util_now_ms() });
                } else {
                    core.*.codex_session_id = _zag_strdup(session.*.id);
                    core.*.codex_event_seen = 0;
                    core.*.codex_assistant_text = "";
                    core.*.codex_input_tokens = 0;
                    core.*.codex_output_tokens = 0;
                    core.*.codex_usage_known = false;
                    core.*.codex_started_ms = util_now_ms();
                    core.*.codex_timed_out = false;
                }
                core_event(core, AppEventKind.agent_status, session.*.id, "thinking", "");
                return true;
            }
            core_event(core, AppEventKind.agent_status, session.*.id, "thinking", "");
            let reply: []u8 = _zag_str_concat("Simulator reply: ", cmd.*.payload);
            core_event(core, AppEventKind.stream_delta, session.*.id, reply, "");
            let aid: []u8 = util_nanoid(12);
            let assistant: []u8 = message_json(aid, session.*.id, "assistant", reply,
                "deterministic", "test-simulator", 0, 0, 0, util_now_ms());
            store_append_message(core.*.store, session.*.id, assistant);
            session.*.message_count = session.*.message_count + 1;
            store_touch(core.*.store, session);
            core_event(core, AppEventKind.assistant_added, session.*.id, reply, "");
            core_event(core, AppEventKind.agent_status, session.*.id, "done", "");
            return true;
        }
        return core_reject(core, cmd, "E_SESSION_NOT_FOUND", "The active session no longer exists.");
    }
    if (cmd.*.kind == AppCommandKind.provider_open) {
        if (core_find_provider(core, cmd.*.payload)) |provider| {
            core_event(core, AppEventKind.provider_changed, "", provider.*.id, "");
            return true;
        }
        return core_reject(core, cmd, "E_PROVIDER_UNKNOWN", "The provider identity is not in the verified catalog.");
    }
    if (cmd.*.kind == AppCommandKind.provider_select) {
        if (core_find_provider(core, cmd.*.payload)) |provider| {
            if (!provider.*.available) { return core_reject(core, cmd, "E_PROVIDER_UNAVAILABLE", "The provider executable is unavailable."); }
            if (!str_eq(provider.*.id, "cline") && !str_eq(provider.*.id, "codex")) {
                return core_reject(core, cmd, "E_PROVIDER_EXECUTOR_UNAVAILABLE", "This CLI executor is not implemented yet.");
            }
            if (!provider.*.authenticated) {
                let guidance: []u8 = "Cline is not authenticated. Run cline auth, then refresh providers.";
                if (str_eq(provider.*.id, "codex")) { guidance = "Codex is not authenticated. Run codex login, then refresh providers."; }
                return core_reject(core, cmd, "E_PROVIDER_AUTH", guidance);
            }
            let previous: []u8 = core.*.selected_provider_id;
            core.*.selected_provider_id = _zag_strdup(provider.*.id);
            if (!core_save_settings(core)) {
                core.*.selected_provider_id = previous;
                return core_reject(core, cmd, "E_SETTINGS_WRITE", "The provider selection could not be saved.");
            }
            core_event(core, AppEventKind.provider_changed, "", provider.*.id, "");
            return true;
        }
        return core_reject(core, cmd, "E_PROVIDER_UNKNOWN", "The provider identity is not in the verified catalog.");
    }
    if (cmd.*.kind == AppCommandKind.provider_refresh) {
        let _found: i32 = core_refresh_providers(core, _zag_getenv("PATH"));
        return true;
    }
    if (cmd.*.kind == AppCommandKind.setting_always_create_session) {
        if (!str_eq(cmd.*.payload, "true") && !str_eq(cmd.*.payload, "false")) {
            return core_reject(core, cmd, "E_SETTING_VALUE", "The setting value must be true or false.");
        }
        let previous: bool = core.*.always_create_session;
        core.*.always_create_session = str_eq(cmd.*.payload, "true");
        if (!core_save_settings(core)) {
            core.*.always_create_session = previous;
            return core_reject(core, cmd, "E_SETTINGS_WRITE", "The session preference could not be saved.");
        }
        core_event(core, AppEventKind.setting_changed, "", cmd.*.payload, "");
        return true;
    }
    if (cmd.*.kind == AppCommandKind.memory_save || cmd.*.kind == AppCommandKind.rules_save) {
        if (cmd.*.payload.len > 1048576) {
            return core_reject(core, cmd, "E_KNOWLEDGE_TOO_LARGE", "Project knowledge files are limited to 1 MiB each.");
        }
        let path: []u8 = core_memory_path(core);
        let label: []u8 = "memory";
        if (cmd.*.kind == AppCommandKind.rules_save) { path = core_rules_path(core); label = "rules"; }
        if (!util_write_atomic(path, cmd.*.payload)) {
            return core_reject(core, cmd, "E_KNOWLEDGE_WRITE", "The Markdown knowledge file could not be saved.");
        }
        if (cmd.*.kind == AppCommandKind.memory_save) { core.*.memory_text = _zag_strdup(cmd.*.payload); }
        else { core.*.rules_text = _zag_strdup(cmd.*.payload); }
        core_event(core, AppEventKind.knowledge_changed, "", label, "");
        return true;
    }
    if (cmd.*.kind == AppCommandKind.message_cancel) {
        if (core.*.codex_run) |run| { return codex_cancel(run); }
        if (core.*.cli_run) |run| {
            run.*.cancelled = true;
            util_kill_child(run.*.pid);
            return true;
        }
        return core_reject(core, cmd, "E_PROVIDER_IDLE", "There is no running provider turn to cancel.");
    }
    if (cmd.*.kind == AppCommandKind.service_tick) { core_tick(core); return true; }
    if (cmd.*.kind == AppCommandKind.recovery_retry) {
        if (core_check_schema(core) && core_load_settings(core)) {
            core.*.ready = true;
            core.*.error_code = "";
            core_event(core, AppEventKind.startup_ready, core.*.active_session_id, "recovery succeeded", "");
            return true;
        }
        return core_reject(core, cmd, "E_STORAGE_SCHEMA", "Recovery could not validate the schema.");
    }
    return core_reject(core, cmd, "E_COMMAND_UNSUPPORTED", "This command is not implemented.");
}

fn core_command(kind: AppCommandKind, sid: []u8, payload: []u8) AppCommand {
    return AppCommand{ .kind = kind, .session_id = sid, .payload = payload, .force = false };
}

fn core_forced_command(kind: AppCommandKind, sid: []u8, payload: []u8) AppCommand {
    return AppCommand{ .kind = kind, .session_id = sid, .payload = payload, .force = true };
}

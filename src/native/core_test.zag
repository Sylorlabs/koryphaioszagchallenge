@import("core.zag")

fn check(name_: []u8, ok: bool, failures: *i32) void {
    if (ok) { _zag_print("  ok  "); } else { _zag_print("  XX  "); failures.* = failures.* + 1; }
    _zag_println(name_);
}

fn main() i32 {
    let failures: i32 = 0;
    let root: []u8 = _zag_str_concat("/tmp/koryphaios-core-", _zag_i64_to_str(util_getpid()));
    let production_root: []u8 = _zag_str_concat(root, "-production");
    let production: *AppCore = core_open(production_root);
    let production_session: AppCommand = core_command(AppCommandKind.session_new, "", "Production chat");
    let _production_created: bool = core_dispatch(production, &production_session);
    let production_send: AppCommand = core_command(AppCommandKind.message_send, "", "must not persist");
    check("production chat fails closed before persistence without an executor",
        !core_dispatch(production, &production_send) &&
        str_eq(get[*AppEvent](production.*.events, production.*.events.len - 1).*.code, "E_PROVIDER_REQUIRED") &&
        get[*Session](production.*.store.*.sessions, 0).*.message_count == 0 &&
        str_eq(store_messages_raw(production.*.store, production.*.active_session_id), "[]"), &failures);

    let core: *AppCore = core_open_test(root);
    check("startup reaches ready only after schema and provider catalog", core.*.ready, &failures);
    check("provider identities remain distinct", core.*.providers.len == 12 &&
        core_find_provider(core, "google-ai-studio") != null &&
        core_find_provider(core, "google-api") != null &&
        core_find_provider(core, "vertex-ai") != null &&
        core_find_provider(core, "jules") != null &&
        core_find_provider(core, "gemini-cli") != null, &failures);

    let fake_bin: []u8 = _zag_str_concat(root, "/bin");
    util_mkdir(fake_bin);
    let fake_codex: []u8 = _zag_str_concat(fake_bin, "/codex");
    util_write_atomic(fake_codex, "#!/bin/sh\nexit 0\n");
    util_chmod(fake_codex, 493);
    check("PATH detection requires an executable and ignores empty entries",
        str_eq(core_find_executable_in_path("codex", _zag_str_concat(":", fake_bin)), fake_codex) &&
        core_find_executable_in_path("missing", fake_bin).len == 0, &failures);
    let auth_home: []u8 = _zag_str_concat(root, "/auth-home");
    util_mkdir(auth_home); util_mkdir(_zag_str_concat(auth_home, "/.cline"));
    util_mkdir(_zag_str_concat(auth_home, "/.cline/data"));
    util_write_atomic(_zag_str_concat(auth_home, "/.cline/data/secrets.json"), "{\"provider\":\"configured\"}");
    check("Cline authentication is derived from its own parseable secret store",
        core_cline_authenticated(auth_home) && !core_cline_authenticated(fake_bin), &failures);

    let fake_cline: []u8 = _zag_str_concat(fake_bin, "/cline");
    let cline_args: []u8 = _zag_str_concat(root, "/cline-args");
    util_write_atomic(fake_cline, _zag_str_concat("#!/bin/sh\nprintf '%s\\n' \"$@\" > '",
        _zag_str_concat(cline_args, "'\nprintf '%s\\n' '{\"type\":\"say\",\"say\":\"text\",\"text\":\"Cline\"}'\nprintf '%s\\n' '{\"type\":\"say\",\"say\":\"text\",\"text\":\"Cline complete\"}'\nexit 0\n")));
    util_chmod(fake_cline, 493);
    let refreshed: i32 = core_refresh_providers(production, fake_bin);
    if (core_find_provider(production, "cline")) |cline_provider| { cline_provider.*.authenticated = true; }
    let select_cline: AppCommand = core_command(AppCommandKind.provider_select, "", "cline");
    check("real Cline executor selection requires detected executable",
        refreshed >= 2 && core_dispatch(production, &select_cline) &&
        str_eq(production.*.selected_provider_id, "cline"), &failures);
    let injection_marker: []u8 = _zag_str_concat(production_root, "/shell-injection-must-not-exist");
    let real_send: AppCommand = core_command(AppCommandKind.message_send, "",
        _zag_str_concat("$(touch ", _zag_str_concat(injection_marker, ")")));
    let real_started: bool = core_dispatch(production, &real_send);
    if (!real_started) {
        let failure_event: *AppEvent = get[*AppEvent](production.*.events, production.*.events.len - 1);
        _zag_print("  diagnostic Cline start: "); _zag_print(failure_event.*.code); _zag_print(" "); _zag_println(failure_event.*.payload);
    }
    check("Cline turn starts asynchronously through direct execve", real_started &&
        production.*.cli_run != null, &failures);
    let spins: i32 = 0;
    while (core_cli_running(production) && spins < 100000) { core_tick(production); spins = spins + 1; }
    let production_messages: []u8 = store_messages_raw(production.*.store, production.*.active_session_id);
    if (get[*Session](production.*.store.*.sessions, 0).*.message_count != 2 ||
        str_index_of(production_messages, "Cline complete") < 0) {
        _zag_print("  diagnostic Cline finish spins="); _zag_print(_zag_i64_to_str(spins as i64));
        _zag_print(" count="); _zag_print(_zag_i64_to_str(get[*Session](production.*.store.*.sessions, 0).*.message_count));
        _zag_print(" messages="); _zag_println(production_messages);
    }
    check("Cline NDJSON snapshots stream once and persist assistant output",
        !core_cli_running(production) &&
        get[*Session](production.*.store.*.sessions, 0).*.message_count == 2 &&
        str_index_of(production_messages, "Cline complete") >= 0 &&
        str_index_of(util_read_or_empty(cline_args), "--plan\n--json\n--auto-approve\nfalse\n--cwd") >= 0 &&
        util_read_or_empty(injection_marker).len == 0, &failures);

    util_write_atomic(fake_cline, "#!/bin/sh\nwhile :; do :; done\n");
    util_chmod(fake_cline, 493);
    let long_send: AppCommand = core_command(AppCommandKind.message_send, "", "cancel this turn");
    let long_started: bool = core_dispatch(production, &long_send);
    let cancel_turn: AppCommand = core_command(AppCommandKind.message_cancel, production.*.active_session_id, "");
    let cancel_sent: bool = core_dispatch(production, &cancel_turn);
    spins = 0;
    while (core_cli_running(production) && spins < 100000) { core_tick(production); spins = spins + 1; }
    check("Cline cancellation sends SIGTERM, reaps the child, and emits cancelled",
        long_started && cancel_sent && !core_cli_running(production) &&
        get[*AppEvent](production.*.events, production.*.events.len - 1).*.kind == AppEventKind.agent_status &&
        str_eq(get[*AppEvent](production.*.events, production.*.events.len - 1).*.payload, "cancelled"), &failures);
    let timeout_send: AppCommand = core_command(AppCommandKind.message_send, "", "timeout this turn");
    let timeout_started: bool = core_dispatch(production, &timeout_send);
    if (production.*.cli_run) |timeout_run| { timeout_run.*.started_ms = 0; }
    spins = 0;
    while (core_cli_running(production) && spins < 100000) { core_tick(production); spins = spins + 1; }
    let saw_timeout: bool = false;
    let event_i: i32 = 0;
    while (event_i < production.*.events.len) {
        if (str_eq(get[*AppEvent](production.*.events, event_i).*.code, "E_PROVIDER_TIMEOUT")) { saw_timeout = true; }
        event_i = event_i + 1;
    }
    check("Cline timeout kills and reaps the child with a stable error code",
        timeout_started && !core_cli_running(production) && saw_timeout, &failures);

    util_write_atomic(fake_codex,
        "#!/bin/sh\nprintf '%s\\n' '{\"type\":\"thread.started\",\"thread_id\":\"native-core\"}' '{\"type\":\"item.completed\",\"item\":{\"type\":\"agent_message\",\"text\":\"Codex native reply\"}}' '{\"type\":\"turn.completed\",\"usage\":{\"input_tokens\":17,\"output_tokens\":5}}'\nexit 0\n");
    util_chmod(fake_codex, 493);
    if (core_find_provider(production, "codex")) |codex_provider| { codex_provider.*.authenticated = true; }
    let select_codex: AppCommand = core_command(AppCommandKind.provider_select, "", "codex");
    let codex_selected: bool = core_dispatch(production, &select_codex);
    let codex_send: AppCommand = core_command(AppCommandKind.message_send, "", "run through codex");
    let codex_started: bool = core_dispatch(production, &codex_send);
    spins = 0;
    while (core_cli_running(production) && spins < 100000) { core_tick(production); spins = spins + 1; }
    let codex_messages: []u8 = store_messages_raw(production.*.store, production.*.active_session_id);
    check("Codex selection executes JSONL, persists exact usage, and finishes asynchronously",
        codex_selected && codex_started && !core_cli_running(production) &&
        str_index_of(codex_messages, "Codex native reply") >= 0 &&
        str_index_of(codex_messages, "\"tokensIn\":17") >= 0 &&
        str_index_of(codex_messages, "\"tokensOut\":5") >= 0, &failures);

    let make_session: AppCommand = core_command(AppCommandKind.session_new, "", "Native workflow");
    check("session_new command succeeds", core_dispatch(core, &make_session), &failures);
    check("session is selected and persisted", core.*.store.*.sessions.len == 1 &&
        core.*.active_session_id.len == 12 &&
        util_read_or_empty(_zag_str_concat(root, "/sessions.json")).len > 2, &failures);

    let first_id: []u8 = _zag_strdup(core.*.active_session_id);
    let reuse: AppCommand = core_command(AppCommandKind.session_new, "", "Should not duplicate");
    check("new session reuses the active untouched composer by default",
        core_dispatch(core, &reuse) && core.*.store.*.sessions.len == 1 &&
        str_eq(core.*.active_session_id, first_id), &failures);

    let force_new: AppCommand = core_forced_command(AppCommandKind.session_new, "", "Forced session");
    check("force-new override creates a distinct untouched session",
        core_dispatch(core, &force_new) && core.*.store.*.sessions.len == 2 &&
        !str_eq(core.*.active_session_id, first_id), &failures);
    let forced_id: []u8 = _zag_strdup(core.*.active_session_id);
    let rename: AppCommand = core_command(AppCommandKind.session_rename, forced_id, "Renamed native session");
    check("session rename writes through atomically",
        core_dispatch(core, &rename) &&
        str_eq(get[*Session](core.*.store.*.sessions, 1).*.title, "Renamed native session") &&
        str_index_of(util_read_or_empty(_zag_str_concat(root, "/sessions.json")), "Renamed native session") >= 0, &failures);
    let remove: AppCommand = core_command(AppCommandKind.session_delete, forced_id, "");
    check("session delete removes messages and selects a surviving session",
        core_dispatch(core, &remove) && core.*.store.*.sessions.len == 1 &&
        str_eq(core.*.active_session_id, first_id) &&
        util_read_or_empty(_zag_str_concat(_zag_str_concat(root, "/messages/"), _zag_str_concat(forced_id, ".json"))).len == 0,
        &failures);

    let send: AppCommand = core_command(AppCommandKind.message_send, "", "hello from native Zag");
    check("message_send persists user content", core_dispatch(core, &send), &failures);
    let session: *Session = get[*Session](core.*.store.*.sessions, 0);
    let messages: []u8 = store_messages_raw(core.*.store, session.*.id);
    check("test simulator persists user and assistant without estimated usage", session.*.message_count == 2 &&
        str_index_of(messages, "hello from native Zag") >= 0 &&
        str_index_of(messages, "Simulator reply: hello from native Zag") >= 0 &&
        session.*.tokens_in == 0 && session.*.tokens_out == 0, &failures);
    check("test simulator emits ordered status, delta, assistant, and done events",
        core.*.events.len >= 6 &&
        get[*AppEvent](core.*.events, core.*.events.len - 3).*.kind == AppEventKind.stream_delta &&
        get[*AppEvent](core.*.events, core.*.events.len - 2).*.kind == AppEventKind.assistant_added &&
        get[*AppEvent](core.*.events, core.*.events.len - 1).*.kind == AppEventKind.agent_status &&
        str_eq(get[*AppEvent](core.*.events, core.*.events.len - 1).*.payload, "done"),
        &failures);

    let always: AppCommand = core_command(AppCommandKind.setting_always_create_session, "", "true");
    check("always-create preference persists as a real setting", core_dispatch(core, &always) &&
        core.*.always_create_session &&
        str_index_of(util_read_or_empty(_zag_str_concat(root, "/native-settings.json")), "true") >= 0, &failures);
    let preference_first: AppCommand = core_command(AppCommandKind.session_new, "", "Preference one");
    let preference_second: AppCommand = core_command(AppCommandKind.session_new, "", "Preference two");
    let _p1: bool = core_dispatch(core, &preference_first);
    let _p2: bool = core_dispatch(core, &preference_second);
    check("always-create preference overrides untouched-session reuse",
        core.*.store.*.sessions.len == 3, &failures);
    let save_memory: AppCommand = core_command(AppCommandKind.memory_save, "", "# Project memory\n\nKeep exact provider usage only.\n");
    let save_rules: AppCommand = core_command(AppCommandKind.rules_save, "", "# Project rules\n\nNever estimate token counts.\n");
    check("memory and rules write through to authoritative Markdown",
        core_dispatch(core, &save_memory) && core_dispatch(core, &save_rules) &&
        str_eq(util_read_or_empty(_zag_str_concat(root, "/memory/PROJECT.md")), save_memory.payload) &&
        str_eq(util_read_or_empty(_zag_str_concat(root, "/rules/PROJECT.md")), save_rules.payload), &failures);
    let remove_p1: AppCommand = core_command(AppCommandKind.session_delete,
        get[*Session](core.*.store.*.sessions, 1).*.id, "");
    let _r1: bool = core_dispatch(core, &remove_p1);
    let remove_p2: AppCommand = core_command(AppCommandKind.session_delete,
        get[*Session](core.*.store.*.sessions, 1).*.id, "");
    let _r2: bool = core_dispatch(core, &remove_p2);

    let bad_provider: AppCommand = core_command(AppCommandKind.provider_open, "", "google");
    check("unknown merged provider identity is rejected", !core_dispatch(core, &bad_provider) &&
        get[*AppEvent](core.*.events, core.*.events.len - 1).*.kind == AppEventKind.command_rejected, &failures);

    let reopened: *AppCore = core_open(root);
    check("restart recovers persisted session state", reopened.*.ready &&
        reopened.*.store.*.sessions.len == 1 &&
        get[*Session](reopened.*.store.*.sessions, 0).*.message_count == 2 &&
        reopened.*.always_create_session &&
        str_eq(reopened.*.memory_text, save_memory.payload) &&
        str_eq(reopened.*.rules_text, save_rules.payload), &failures);

    let corrupt_root: []u8 = _zag_str_concat(root, "-corrupt");
    util_mkdir(corrupt_root);
    util_write_atomic(_zag_str_concat(corrupt_root, "/native-schema.json"), "{bad");
    let corrupt: *AppCore = core_open(corrupt_root);
    check("corrupt schema fails closed with backup and stable code", !corrupt.*.ready &&
        str_eq(corrupt.*.error_code, "E_STORAGE_SCHEMA") &&
        util_read_or_empty(_zag_str_concat(corrupt_root, "/native-schema.corrupt.backup")).len > 0, &failures);

    let settings_root: []u8 = _zag_str_concat(root, "-settings-corrupt");
    util_mkdir(settings_root);
    util_write_atomic(_zag_str_concat(settings_root, "/native-schema.json"), "{\"schemaVersion\":1,\"format\":\"koryphaios-native\"}");
    util_write_atomic(_zag_str_concat(settings_root, "/native-settings.json"), "{bad");
    let settings_corrupt: *AppCore = core_open(settings_root);
    check("corrupt settings fail closed with backup and stable code", !settings_corrupt.*.ready &&
        str_eq(settings_corrupt.*.error_code, "E_SETTINGS_SCHEMA") &&
        util_read_or_empty(_zag_str_concat(settings_root, "/native-settings.corrupt.backup")).len > 0, &failures);

    if (failures == 0) { _zag_println("NATIVE CORE: ALL PASS"); return 0; }
    _zag_println("NATIVE CORE: FAILURES"); return 1;
}

# Koryphaios — Environment Variable Configuration
# Copy this file to .env and fill in the API keys for providers you want to use.
# All variables are optional — only set what you need.

# ── Frontier Providers ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_AUTH_TOKEN=your_auth_token_here
OPENAI_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here
GOOGLE_API_KEY=your_key_here
GEMINI_AUTH_TOKEN=your_auth_token_here
XAI_API_KEY=your_key_here

# ── Aggregators ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_key_here
OPENROUTER_BASE_URL=your_base_url_here
GROQ_API_KEY=your_key_here

# ── Auth-only Providers (OAuth / CLI token) ─────────────────────────────────
CLAUDE_CODE_OAUTH_TOKEN=your_oauth_token_here
GITHUB_COPILOT_TOKEN=your_github_token_here
GITHUB_TOKEN=your_github_token_here
CODEX_AUTH_TOKEN=your_auth_token_here
KIMI_CODE_AUTH_TOKEN=your_auth_token_here

# ── Curated Coding Models ───────────────────────────────────────────────────
OPENCODE_ZEN_API_KEY=your_key_here

# ── Enterprise ──────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your_key_here
AZURE_OPENAI_AUTH_TOKEN=your_auth_token_here
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.cognitiveservices.azure.com
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
GOOGLE_VERTEX_AI_API_KEY=your_key_here

# ── Local / Self-hosted ─────────────────────────────────────────────────────
LOCAL_ENDPOINT=http://localhost:1234/v1
OLLAMA_BASE_URL=http://localhost:11434
LLAMACPP_BASE_URL=http://127.0.0.1:8080/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# ── OpenCode Parity Providers ───────────────────────────────────────────────
A302AI_API_KEY=your_key_here
AZURE_COGNITIVE_API_KEY=your_key_here
AZURE_COGNITIVE_RESOURCE_URL=https://YOUR_RESOURCE.cognitiveservices.azure.com
BASETEN_API_KEY=your_key_here
CEREBRAS_API_KEY=your_key_here
CLOUDFLARE_API_TOKEN=your_token_here
DEEPSEEK_API_KEY=your_key_here
DEEPINFRA_API_KEY=your_key_here
FIRMWARE_API_KEY=your_key_here
FIREWORKS_API_KEY=your_key_here
GITLAB_API_KEY=your_key_here
HUGGINGFACE_API_KEY=your_key_here
HELICONE_API_KEY=your_key_here
IONET_API_KEY=your_key_here
MISTRAL_API_KEY=your_key_here
MOONSHOT_API_KEY=your_key_here
MINIMAX_API_KEY=your_key_here
NEBIUS_API_KEY=your_key_here
OLLAMA_CLOUD_API_KEY=your_key_here
AICORE_SERVICE_KEY=your_sap_ai_core_service_key_here
STACKIT_API_KEY=your_key_here
OVHCLOUD_API_KEY=your_key_here
SCALEWAY_API_KEY=your_key_here
TOGETHER_API_KEY=your_key_here
VENICE_API_KEY=your_key_here
VERCEL_AI_API_KEY=your_key_here
ZAI_API_KEY=your_key_here
ZENMUX_API_KEY=your_key_here

# ── Server / Runtime ────────────────────────────────────────────────────────
# KORYPHAIOS_PORT=3001
# KORYPHAIOS_HOST=127.0.0.1
# KORYPHAIOS_MODE=beginner
# DATABASE_URL=sqlite://data/koryphaios.db
# CORS_ORIGINS=http://localhost:5173,http://localhost:3003
# Optional self-host override. Packaged apps default to https://koryphaios.com/api/feedback.
# KORYPHAIOS_FEEDBACK_ENDPOINT=https://your-koryphaios-host.example/api/feedback

# ── Messaging Bridges ───────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_ADMIN_ID=your_admin_id_here
# TELEGRAM_SECRET_TOKEN=your_secret_token_here
# DISCORD_BOT_TOKEN=your_bot_token_here
# DISCORD_ALLOWED_GUILD_IDS=id1,id2
# DISCORD_ALLOWED_USER_IDS=id1,id2
# SLACK_BOT_TOKEN=your_bot_token_here
# SLACK_APP_TOKEN=your_app_token_here
# SLACK_SIGNING_SECRET=your_signing_secret_here
# SLACK_ALLOWED_CHANNEL_IDS=id1,id2
# SLACK_ALLOWED_USER_IDS=id1,id2

{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "build": "bun run typecheck && bun build src/server.ts --outdir=./build --target=bun",
    "typecheck": "tsc --noEmit",
    "test": "SESSION_TOKEN_SECRET=${SESSION_TOKEN_SECRET:-test_only_not_for_production_aaaaaaaaaa} NODE_ENV=test bun test",
    "test:all": "SESSION_TOKEN_SECRET=${SESSION_TOKEN_SECRET:-test_only_not_for_production_aaaaaaaaaa} NODE_ENV=test bun test",
    "test:watch": "SESSION_TOKEN_SECRET=${SESSION_TOKEN_SECRET:-test_only_not_for_production_aaaaaaaaaa} NODE_ENV=test bun test --watch"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.30.2",
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-kms": "^3.1020.0",
    "@elysiajs/cors": "^1.4.2",
    "@google/genai": "^1.0.0",
    "@koryphaios/shared": "workspace:*",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.57.2",
    "@opentelemetry/instrumentation": "0.57.2",
    "@opentelemetry/instrumentation-http": "0.57.2",
    "@opentelemetry/resources": "1.30.1",
    "@opentelemetry/sdk-trace-node": "1.30.1",
    "@opentelemetry/semantic-conventions": "1.39.0",
    "better-sqlite3": "^11.7.0",
    "bullmq": "^5.79.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "ioredis": "5.10.1",
    "jsonwebtoken": "9.0.3",
    "nanoid": "^5.0.0",
    "openai": "^4.77.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^3.0.0",
    "werift": "^0.23.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/bun": "^1.3.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  }
}

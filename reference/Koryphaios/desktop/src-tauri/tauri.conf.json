{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Koryphaios",
  "version": "1.0.22",
  "identifier": "com.sylorlabs.koryphaios",
  "build": {
    "frontendDist": "../../frontend/build/client",
    "devUrl": "http://127.0.0.1:3003",
    "beforeDevCommand": null,
    "beforeBuildCommand": "cd ../frontend && bun run build",
    "features": null
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Koryphaios",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "maxWidth": 3840,
        "maxHeight": 2160,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "visible": true,
        "focus": true,
        "useHttpsScheme": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:*",
        "img-src": "'self' data: https:",
        "style-src": "'self' 'unsafe-inline'",
        "script-src": "'self' 'unsafe-eval'",
        "font-src": "'self' data:",
        "frame-src": "'self' https: http:"
      },
      "dangerousDisableAssetCspModification": false,
      "capabilities": []
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "The Autonomous Workspace for 100% AI-Generated Code",
    "longDescription": "Koryphaios is a full-stack application that orchestrates AI agents across multiple providers with intelligent routing, task delegation, and real-time streaming.",
    "publisher": "Sylorlabs",
    "copyright": "Copyright (c) 2024 Sylorlabs",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "signingIdentity": null,
      "entitlements": null
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "resources": {
      "../../config": "config",
      "../../frontend/build/client": "frontend"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": ["https://github.com/Sylorlabs/Koryphaios/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdFMUI1QzIzQzI4QjM2OTQKUldTVU5vdkNJMXdiZmhSbzU4QWI4OTlzN0ROdWpOdTNtaUpPWVBaS3RKNURJMktSUVlUVWRiMWcK"
    }
  }
}

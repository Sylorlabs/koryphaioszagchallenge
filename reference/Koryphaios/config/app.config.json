{
  "app": {
    "name": "Koryphaios",
    "version": "0.2.0",
    "identifier": "com.sylorlabs.koryphaios"
  },
  "server": {
    "host": "127.0.0.1",
    "port": 3001,
    "wsPath": "/ws"
  },
  "window": {
    "width": 1280,
    "height": 800,
    "minWidth": 1024,
    "minHeight": 640,
    "maxWidth": 3840,
    "maxHeight": 2160
  },
  "security": {
    "csp": {
      "defaultSrc": ["'self'"],
      "connectSrc": [
        "'self'",
        "http://127.0.0.1:*",
        "http://localhost:*",
        "ws://127.0.0.1:*",
        "ws://localhost:*",
        "wss:",
        "https:"
      ],
      "imgSrc": ["'self'", "data:", "blob:", "https:"],
      "styleSrc": ["'self'", "'unsafe-inline'", "https://fonts.googleapis.com"],
      "scriptSrc": ["'self'"],
      "fontSrc": ["'self'", "data:", "https://fonts.gstatic.com", "https://geistfont.vercel.app"]
    }
  }
}
